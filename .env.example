#############################################
# LLM 通用配置
#############################################
# 可选: gemini | openai | deepseek | qwen
LLM_PROVIDER=gemini

# 可按 provider 覆盖默认模型
# Gemini 默认: gemini-2.5-flash
# OpenAI 默认: gpt-4o-mini
# DeepSeek 默认: deepseek-chat
# Qwen 默认: qwen-plus
LLM_MODEL=gemini-2.5-flash

# 推理参数
LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=2048

# 是否启用真实 LLM（0=mock, 1=real）
USE_REAL_LLM=1

# 真实 LLM 失败时是否允许回退 mock（建议测试时关闭）
# 1=允许回退 mock, 0=禁用回退 mock
ALLOW_MOCK_FALLBACK=0

#############################################
# Provider API Keys（只填一个即可）
#############################################
# Gemini
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
